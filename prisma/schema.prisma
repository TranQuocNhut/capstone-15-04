generator client {
  provider      = "prisma-client"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  userId      Int       @id @default(autoincrement())
  email       String    @unique
  password    String
  fullName    String
  age         Int
  avatar      String?
  images      Image[]
  comments    Comment[]
  savedImages Save[]
}

model Image {
  imageId     Int       @id @default(autoincrement())
  imageName   String
  url         String    
  provider    String   
  storagePath String   
  description String?
  userId      Int
  user        User      @relation(fields: [userId], references: [userId])
  comments    Comment[]
  savedImages Save[]
}

model Comment {
  commentId   Int      @id @default(autoincrement())
  userId      Int
  imageId     Int
  createdDate DateTime @default(now())
  content     String
  user        User     @relation(fields: [userId], references: [userId])
  image   Image @relation(fields: [imageId], references: [imageId], onDelete: Cascade)
}

model Save {
  userId    Int
  imageId   Int
  savedDate DateTime @default(now())
  user      User     @relation(fields: [userId], references: [userId])
  image   Image @relation(fields: [imageId], references: [imageId], onDelete: Cascade)

  @@id([userId, imageId])
}
